# Assessment-Agent — 환경변수 template.
# 실제 `.env` 파일은 본 template 을 복사 후 값을 채워 사용한다.
# `.env` 는 `.gitignore` 에 등록되어 있어 commit 되지 않는다 (CLAUDE.md §9 secret 보호).
#
# 사용법:
#   cp .env.example .env
#   # 그 후 .env 의 placeholder 를 실제 값으로 교체.

# Prisma 가 읽는 PostgreSQL connection string.
# 형식: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=SCHEMA
# 로컬 docker-compose 와 정합하는 default placeholder.
DATABASE_URL="postgresql://assessment_agent:change_me_in_env@localhost:5432/assessment_agent?schema=public"

# docker-compose.yml 이 참조하는 PostgreSQL 자격 (compose default 와 일치).
POSTGRES_USER=assessment_agent
POSTGRES_PASSWORD=change_me_in_env
POSTGRES_DB=assessment_agent

# 애플리케이션 HTTP 포트 (main.ts 의 fallback 3000).
PORT=3000

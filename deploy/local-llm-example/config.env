# deploy/local-llm-example/config.env
# 로컬 LLM serving 예제 설정 (Ollama 기반). 이 파일은 "예제 기본값"이며 git 에 커밋된다.
#
# 개인별 오버라이드: 같은 폴더에 config.local.env (gitignore 됨) 를 만들어 같은 KEY 를
# 다시 적으면, 모든 스크립트가 config.env 로드 후 config.local.env 로 덮어쓴다.
# (예: 다른 모델을 기본으로 쓰고 싶을 때 config.local.env 에 OLLAMA_MODEL 한 줄만 작성)
#
# 형식: KEY=VALUE (줄 단위). '#' 로 시작하는 줄과 빈 줄은 무시된다.

# pull / serve 할 모델 (Ollama tag). 교체/추가는 https://ollama.com/library 참조.
# RTX 4070(12GB) 기준 안전선은 Q4 기준 ~10GB 이하. 기본값은 2026 최신 Gemma4 12B.
OLLAMA_MODEL=gemma4:12b

# Ollama 서버 bind 주소. 기본은 로컬 전용(127.0.0.1). 같은 LAN 의 다른 PC 에서
# 접근시키려면 0.0.0.0:11434 로 바꾼다 (방화벽/보안 직접 고려할 것).
OLLAMA_HOST=127.0.0.1:11434

# 유휴 시 모델을 VRAM 에서 내리기까지의 시간 (자원 해제 정책의 핵심).
#   5m  : 마지막 요청 5분 뒤 언로드 → 자원 해제와 재로딩 비용의 균형 (기본/권장)
#   0   : 매 요청 직후 즉시 언로드 → 다른 프로세스에 최대한 양보, 단 매번 재로딩
#   -1  : 무기한 상주 (언로드 안 함) → 재로딩 0, 단 VRAM 계속 점유
OLLAMA_KEEP_ALIVE=5m

# OpenAI 호환 endpoint. Assessment-Agent 의 LLM provider config 의 endpointUrl 에
# 그대로 넣는 값이다. Ollama 는 /v1 경로로 OpenAI Chat Completions 호환 API 를 연다.
OPENAI_BASE_URL=http://127.0.0.1:11434/v1

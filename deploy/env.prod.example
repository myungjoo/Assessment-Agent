# Assessment-Agent — 운영(docker compose) 환경변수 template.
# 사용법:
#   cp deploy/env.prod.example .env      # repo 루트에 .env 로 둔다
#   # 이후 아래 placeholder 를 실제 값으로 교체
# .env 는 .gitignore 대상 — 절대 commit 금지 (CLAUDE.md §9).

# --- PostgreSQL 컨테이너 자격 (docker-compose.yml 의 postgres 서비스) ---
POSTGRES_USER=assessment_agent
POSTGRES_PASSWORD=<강력한_DB_비밀번호로_교체>
POSTGRES_DB=assessment_agent

# --- 앱이 사용하는 DB 연결 문자열 (Prisma) ---
# 중요: docker compose 안에서 app → db 는 서비스 이름 'postgres' 로 접근한다
#       (localhost 가 아님). user/password/db 는 위 세 값과 반드시 일치시킬 것.
DATABASE_URL="postgresql://assessment_agent:<위와_동일한_비밀번호>@postgres:5432/assessment_agent?schema=public"

# --- 앱 HTTP 포트 (main.ts fallback 3000) ---
PORT=3000

# --- 인증 JWT 서명 secret (ADR-0008, AUTH_JWT_SECRET) ---
# 운영에서 비우면 서명 검증이 무력화된다 — 반드시 길고 무작위한 값으로 채울 것.
# 생성 예: openssl rand -hex 32
AUTH_JWT_SECRET=<openssl_rand_hex_32_로_생성한_값>

# --- (선택) 사내 PKI 인증서 신뢰 / 프록시 (deployment.md "외부 네트워크" 단락) ---
# 아래 값을 쓰려면 인증서 파일을 app 컨테이너에 volume 으로 mount 해야 한다 (deploy/README.md 참조).
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/corp-ca-bundle.pem
# HTTPS_PROXY=http://proxy.example:8080
# NO_PROXY=localhost,127.0.0.1,postgres

# Docker build context 제외 — 이미지 빌드 입력 최소화 + secret/산출물 유출 차단.
# 의존성·빌드 산출물은 Dockerfile builder 단계가 컨테이너 안에서 새로 생성한다.
node_modules
**/node_modules
dist
web/dist
build
coverage
.nyc_output

# git / 메타
.git
.gitignore
.github

# 환경변수 secret — 절대 이미지에 굽지 않는다 (CLAUDE.md §9). 런타임은 env_file 로 주입.
.env
.env.*
!.env.example

# 로그 / 에디터 / harness 메타
*.log
.idea
.vscode
.claude

# Docker 자체 메타 (이미지 안에 불필요)
Dockerfile
.dockerignore

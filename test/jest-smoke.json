{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": ".*\\.smoke-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "globalSetup": "<rootDir>/test/helpers/jest-smoke-setup.ts",
  "testEnvironment": "node",
  "passWithNoTests": false,
  "maxWorkers": 1
}

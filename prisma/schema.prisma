// Prisma schema — T-0033 (init) + T-0034 (Person model + 첫 migration) +
// T-0035 (ServiceIdentity model + Person↔ServiceIdentity 1:N relation +
// `@@unique([personId, service])` invariant) 위에
// T-0039 가 Group + Part + PersonGroupMembership (join) model 3 종과
// Person↔Part N:1 + Person↔Group N:M (via join) relation 을 추가한다.
//
// Prisma 7.x 모델 (Prisma 5.x 와 차이):
//   - datasource.url 은 schema 가 아닌 `prisma.config.ts` 에서 adapter 로 inject.
//     본 schema 는 provider 만 박제 — runtime connection 은 PrismaClient 의 adapter
//     생성자 옵션 (`@prisma/adapter-pg`) 가 DATABASE_URL 을 읽어 pg Pool 을 구성.
//   - 추가 dependency `@prisma/adapter-pg` 가 본 결정의 implication 으로 자동 도입
//     (T-0033 acceptance).
//
// T-0039 책임 범위:
//   - Group model 1 개 추가 (id / name / createdAt / updatedAt).
//   - Part model 1 개 추가 (id / name unique / createdAt / updatedAt).
//   - PersonGroupMembership join model (id / personId / groupId / createdAt;
//     `@@unique([personId, groupId])` — 동일 Person 의 동일 Group 중복 소속 금지).
//   - Person.partId nullable + Person.part / Person.groups relation 필드.
//   - Part.persons / Group.memberships reverse relation 필드.
//
// 본 task 의 schema 차원 결정:
//   - Person.partId 는 **nullable** 유지. REQ-028 의 mandatory 1 Part invariant 는
//     service-layer (후속 T-0040) 책임. 본 task 는 schema 차원에서 (a) 기존 Person
//     row 의 default Part seed migration 부재 + (b) NOT NULL 전환 의 2 단계 cost
//     를 회피 — nullable + Follow-up 명시.
//   - Person → Part cascade: `onDelete: SetNull` 채택 안 함, default `Restrict`
//     (Prisma 의 default behaviour — FK constraint 가 P2003 throw). 이유: REQ-028
//     "Part 정확히 1" invariant 의 schema 차원 enforce — 소속 Person 1+ 일 때 Part
//     삭제를 막아 dangling reference 자체를 차단. 모든 Person 을 다른 Part 로
//     재배치한 뒤에야 Part 삭제 가능 (service-layer 책임).
//   - PersonGroupMembership → Person cascade: `onDelete: Cascade` — Person 삭제 시
//     모든 membership row 동반 삭제. 단 Person 의 hard delete 는 REQ-026 에 따라
//     발생 안 함 (soft delete `active=false`), 본 cascade 는 안전망.
//   - PersonGroupMembership → Group cascade: `onDelete: Cascade` — Group 삭제 시
//     모든 membership row 동반 삭제. Group 은 hard delete 채택 (소속 Person 0+
//     무관 — REQ-028 "임의 group" semantics 가 Group 의 자유로운 삭제 허용).
//
// 추가 entity (User / Assessment / Contribution / Summary / LlmProviderConfig /
// DifficultyMapping / PermissionDeniedRecord) 는 T-0040+ 의 책임이므로 본 task
// 의 Out of Scope.

datasource db {
  provider = "postgresql"
}

// Prisma Client (TypeScript) 생성기. NestJS service / controller 가 사용할 type 의 source.
generator client {
  provider = "prisma-client-js"
}

// Person — data-model.md §2 row 1 의 최소 컬럼 + ServiceIdentity 1:N relation.
// T-0035 가 `serviceIdentities` relation 필드를 추가 — Prisma 의 양방향 relation
// 요건 (back-relation 필드 필수). 추가 컬럼 (group / part / 동명이인 등) 은 T-0036+.
model Person {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 1 Person 은 0+ 개의 ServiceIdentity 를 가진다 (REQ-023 / data-model.md §3 관계 1).
  // hard delete 시 Cascade 로 ServiceIdentity 동반 삭제 (ServiceIdentity model 의
  // `onDelete: Cascade` 가 양방향 의미를 박제). soft delete (active=false) 시에는
  // 본 cascade 발동 안 함 — ServiceIdentity 는 그대로 보존.
  serviceIdentities ServiceIdentity[]

  // T-0039 — Person ↔ Part N:1 (mandatory in service-layer; schema 차원 nullable).
  // REQ-028 의 "조직도 파트 정확히 1" invariant 의 service-layer 강제는 후속 T-0040
  // 책임. 본 task 는 schema 차원에서 nullable 유지 + Follow-up 명시.
  // Part 삭제 시 본 row 의 partId 는 default `Restrict` (FK constraint P2003) 로
  // 보호된다 — 모든 Person 의 part 가 재배치된 후에야 Part 삭제 가능.
  partId String?
  part   Part?   @relation(fields: [partId], references: [id])

  // T-0039 — Person ↔ Group N:M via PersonGroupMembership join entity.
  // REQ-028 의 "임의 group 다중 소속 가능" semantics — 1 Person 은 0+ Group.
  // PersonGroupMembership 의 `onDelete: Cascade` 가 Person 삭제 시 모든 membership
  // row 를 동반 삭제 (안전망 — Person 은 REQ-026 에 따라 hard delete 채택 안 함).
  groups PersonGroupMembership[]

  // T-0110 (ADR-0006 Decision §1 / §3 / §6) — Person ↔ Assessment / Summary back-relation.
  // 1 Person 은 0+ Assessment (period × scope cross product) + 0+ Summary (일/주/월) 를 가진다.
  // 두 model 모두 `onDelete: Cascade` (해당 model 의 relation 필드가 양방향 의미 박제) —
  // Person 의 hard delete 시 평가 결과 동반 삭제 (단 Person 은 soft delete 채택이라
  // 본 cascade 는 안전망. ServiceIdentity / PersonGroupMembership 의 기존 Cascade 정합).
  assessments Assessment[]
  summaries   Summary[]
}

// Group — data-model.md §2 row 3 + §3 관계 2 + REQ-028 의 schema 차원 박제.
// 1 Person 이 임의 다수 Group 에 소속 가능 (N:M) — PersonGroupMembership join 으로 표현.
// 본 task 는 schema 차원에서 hard delete 채택 — Group 삭제 시 PersonGroupMembership
// row 들이 cascade 동반 삭제. Person 의 part 와 달리 Group 은 "조직도 파트" 가 아닌
// 자유로운 grouping 이므로 자유로운 삭제 허용 (REQ-028 "임의 group" semantics).
model Group {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // reverse relation — 1 Group 은 0+ PersonGroupMembership row 를 가진다.
  memberships PersonGroupMembership[]
}

// Part — data-model.md §2 row 4 + §3 관계 3 + REQ-028 의 schema 차원 박제.
// "조직도 파트" — 1 Person 은 정확히 1 Part 에 소속 (mandatory invariant 는
// service-layer 책임, 본 task 는 schema 차원에서 nullable 유지).
// `name @unique` — 동일 이름의 Part 중복 금지 (조직도의 고유성 가정).
// Part → Person 의 cascade 는 default `Restrict` (Prisma 의 default behaviour) —
// 소속 Person 1+ 인 Part 삭제 시 FK constraint (P2003) 가 throw, dangling
// reference 차단. service-layer 가 사전에 모든 Person 의 part 를 재배치 책임.
model Part {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // reverse relation — 1 Part 는 0+ Person 을 거느린다.
  persons Person[]
}

// PersonGroupMembership — Person ↔ Group 의 N:M join entity (data-model.md §3
// 관계 2). 각 row 가 (personId, groupId) 한 쌍을 박제. `@@unique([personId, groupId])`
// invariant — 동일 Person 의 동일 Group 중복 소속 금지.
//
// cascade 정책 (schema.prisma 헤더 결정 §28–37 참조):
//   - Person 삭제 시 본 row Cascade 동반 삭제 (안전망 — Person 은 soft delete 채택).
//   - Group 삭제 시 본 row Cascade 동반 삭제 (Group 의 자유 삭제 semantics).
model PersonGroupMembership {
  id        String   @id @default(cuid())
  personId  String
  groupId   String
  createdAt DateTime @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([personId, groupId])
}

// User — data-model.md §2 row "User" + REQ-043 (ID/Password) + REQ-044 (3 등급).
// T-0080 — ADR-0008 후속 chain 첫 task. AuthModule (T-0081) 의 prerequisite.
//
// 책임 경계:
//   - 로그인 계정 (서비스 사용자). Person 과 conceptual 분리 — User 는 시스템 인증
//     식별자, Person 은 평가 대상자 (data-model.md §2 박제).
//   - User ↔ Person 0..1:0..1 relation 은 본 task 의 Out of Scope — data-model.md
//     §3 관계 7 의 AuthModule 책임 deferral 정합. 향후 별도 task 가 relation 컬럼
//     (예: personId String? @unique + relation 필드) 추가.
//
// 컬럼 결정:
//   - email @unique — REQ-043 의 로그인 identifier. unique constraint 위반 시
//     Prisma 가 P2002 throw (UserRepository.create 에서 catch 0 — caller 책임).
//   - hashedPassword — raw String. hashing logic (bcrypt / argon2 등) 자체는 T-0081
//     의 AuthService layer 책임 — 본 schema 는 hashed 결과를 저장만 한다 (hashing
//     알고리즘 / cost factor 같은 결정은 ADR-0008 후속 task 가 별도 박제).
//   - role — String literal ("SuperAdmin" / "Admin" / "User") 의 단순 박제. Prisma
//     enum 도입 / role lookup table 격상은 별도 ADR 의 책임 — Person model 의
//     ServiceIdentity.service 컬럼 (String 박제) 정공법 정합. service-layer
//     (T-0081 AuthService) 가 값 invariant 검증 책임. self-demote 차단 (REQ-044)
//     은 T-0083 의 책임.
//   - createdAt / updatedAt — Person / Group / Part 와 동일한 표준 timestamp 패턴.
//
// cascade 정책:
//   - User 삭제 시의 cascade 는 본 task 에서 결정 안 함 — relation 컬럼 부재
//     (Person/RefreshToken 등 후속 entity 와의 관계가 아직 박제 안 됨) 으로 cascade
//     의 적용 대상이 없음. relation 추가 시 별도 task 가 cascade 정책 박제.
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  role           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ServiceIdentity — data-model.md §2 row 2 + §3 관계 1 + REQ-023 / REQ-024 cover.
// 1 Person 의 N 서비스 ID 를 매핑 (github.com / github.sec.samsung.net /
// github.ecodesamsung.com / confluence.sec.samsung.net 등). isPrimary 가 REQ-024
// invariant (1 Person 당 정확히 1 primary) 의 schema-level 표식 — service-layer
// 강제 (정확히 1 row) 는 후속 T-0036 책임. 본 task 는 schema 의 `@@unique` 만 박제.
//
// service 필드는 본 task 에서 String 으로 유지 — enum 도입 / lookup table 격상은
// P4 진입 시 별도 ADR 권장 (task 의 Follow-ups §149 참조).
model ServiceIdentity {
  id         String   @id @default(cuid())
  personId   String
  service    String
  externalId String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Person 과 의 N:1 — Person 의 hard delete 시 ServiceIdentity 도 cascade 삭제.
  // soft delete 의 경우 active flag 만 toggle 이므로 본 cascade 는 발동 안 함.
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  // 1 Person 이 동일 service 의 ID 2 개 가질 수 없음 invariant (REQ-023 변형).
  // 예: 동일 person 이 github.com 의 ID 2 개를 등록할 수 없다 — 서비스 측 user 의
  // 1:1 매핑 가정.
  @@unique([personId, service])
}

// Assessment — ADR-0006 Decision §1 + data-model.md §2 / §3 관계 4 (Person↔Assessment).
// 평가 결과의 unit. Person × period (일/주/월) × scope (commit/document/aggregate) 의
// cross product. 평가 결과값 (난이도/기여도/양/LLM 정성 평가문) 만 보유.
//
// 🔥 raw 본문 컬럼 0 (R-59 / REQ-032 / ADR-0006 Decision §4 schema-level 강제):
//   commit message 본문 / diff / 문서 본문 / Confluence page 본문 컬럼을 **정의하지 않는다**.
//   "저장하지 않는다" 를 application-layer 검증이 아닌 schema 차원 (컬럼 자체의 부재) 으로
//   보장한다 — schema 에 자리가 없으면 저장 자체가 불가. 외부 본문이 필요하면 Contribution 의
//   참조 식별자 (sourceUrl / sourceRef) 로 재수집 (REQ-031). narrative 는 LLM 생성 결과물
//   이므로 raw 아님 (R-59 적용 외).
//
// 컬럼 결정 (ADR-0006 Decision §1 과 1:1):
//   - period / scope / difficulty 는 enum-as-String literal 박제 (ServiceIdentity.service /
//     User.role 정공법 정합 — Prisma enum 격상은 별도 ADR). 값 invariant 는 service-layer 책임.
//   - contributionScore 는 Decimal (정규화 수치 — REQ-036 상대 비교 가능 형태, Float 부동소수
//     오차 회피). @db.Decimal(p,s) 구체 precision/scale 은 후속 schema task 책임 (default 시작).
//   - updatedAt **미정의** — Assessment 는 immutable (재평가는 hard delete 후 재생성,
//     REQ-037/REQ-041). data-model.md §5 정합.
model Assessment {
  id                String   @id @default(cuid())
  personId          String
  period            String
  scope             String
  periodStart       DateTime
  difficulty        String
  contributionScore Decimal
  volume            Int
  narrative         String
  createdAt         DateTime @default(now())

  // Person N:1 — Person 의 hard delete 시 Assessment 동반 cascade (ADR-0006 Decision §6).
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  // 1 Assessment 는 0+ Contribution 으로 구성 (ADR-0006 Decision §2 / §3 관계 5).
  contributions Contribution[]

  // 동일 Person 의 동일 (period, scope, periodStart) 조합 중복 Assessment 차단 →
  // 재수집 중복 방지 (REQ-031) 의 schema-level backbone (ADR-0006 Decision §6).
  @@unique([personId, period, scope, periodStart])
  // 시계열 조회 (REQ-038) 용 index 후보 (ADR-0006 Decision §6).
  @@index([personId, period, periodStart])
}

// Contribution — ADR-0006 Decision §2 + data-model.md §3 관계 5 (Assessment↔Contribution).
// 개별 기여 단위 (단일 commit / 단일 PR / 단일 문서 변경). N Contribution 이 1 Assessment 로
// aggregate. 참조 식별자만 보유, raw 본문 미저장 (REQ-032).
//
// 🔥 raw 본문 컬럼 0 (R-59 / ADR-0006 Decision §4):
//   commit body / diff / 문서 본문 컬럼 정의 안 함. sourceUrl (외부 GitHub / Confluence URL) +
//   sourceRef (commit SHA / PR number / page version ID) 만으로 필요 시 재수집 (REQ-031).
//   sourceUrl / sourceRef 는 외부 본문을 가리키는 pointer 일 뿐 본문 자체가 아님.
//
// updatedAt **미정의** — Contribution 은 immutable (ADR-0006 Decision §2).
model Contribution {
  id                String   @id @default(cuid())
  assessmentId      String
  sourceType        String
  sourceUrl         String
  sourceRef         String
  difficulty        String
  contributionScore Decimal
  volume            Int
  createdAt         DateTime @default(now())

  // Assessment N:1 — Assessment 의 hard delete (REQ-041 Admin manual delete) 시
  // component Contribution 동반 cascade 삭제 (ADR-0006 Decision §6).
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

// Summary — ADR-0006 Decision §3 + data-model.md §3 관계 6 (Person↔Summary).
// 일·주·월 단위 요약 평가문. Person N:1 (default). LLM 정성 평가문 + Metric 수치.
// Group/Part aggregate Summary 는 별도 entity 신설 안 함 — view-time 계산 (ADR-0006
// Alternatives (c) defer). 동일 Group/Part 소속 Person 들의 Summary 를 query-time 집계.
//
// 🔥 raw 본문 컬럼 0 (R-59 / ADR-0006 Decision §4):
//   narrative 는 LLM 정성 요약 평가문 (LLM 생성 결과물 — raw 아님). raw 본문 컬럼 정의 안 함.
//
// updatedAt **미정의** — Summary 는 재계산 가능하나 본 ADR 은 immutable 로 보고 재계산 =
// hard delete 후 재생성으로 처리 (ADR-0006 Decision §3).
model Summary {
  id          String   @id @default(cuid())
  personId    String
  period      String
  periodStart DateTime
  narrative   String
  metricScore Decimal
  createdAt   DateTime @default(now())

  // Person N:1 — Person 의 hard delete 시 Summary 동반 cascade (ADR-0006 Decision §6).
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  // 시계열 조회 (REQ-038) 용 index 후보 (ADR-0006 Decision §6).
  @@index([personId, period, periodStart])
}

// LlmProviderConfig — data-model.md §2 row "LlmProviderConfig" + §3 관계 8 +
// REQ-049/051~055. T-0135 (P4 LLM provider 추상화 scaffold). 5 provider
// (custom / Azure OpenAI / Anthropic / Google Gemini / OpenAI) 별 설정 row —
// endpoint URL / API key / model 식별자.
//
// 컬럼 결정 (T-0135 acceptance §34):
//   - provider 는 enum-as-String literal 박제 (User.role / ServiceIdentity.service /
//     Assessment.period 정공법 정합 — Prisma enum 격상은 별도 ADR). 허용 집합의
//     single source 는 src/llm/llm-gateway.interface.ts 의 LlmProvider enum.
//     값 invariant 는 후속 service (T-0139) 책임.
//   - apiKey 는 평문 String — encryption-at-rest 는 ADR-0006 follow-up 책임. 본
//     task 는 secret 처리 코드 0, 암호화 0 (apiKey 컬럼은 평문 저장 placeholder).
//   - createdAt / updatedAt — Person / Group / Part 와 동일한 표준 timestamp 패턴.
//     LlmProviderConfig 는 mutable entity (data-model.md §5 — updatedAt 적용).
//
// **다중 row 모델** — 각 provider 별 1+ row, custom 은 3 model 슬롯 모두 차지 가능
// (REQ-051). GroupRepository 와 동일하게 `@unique` / `@@unique` **미정의** — unique
// 제약 없음 (P2002 분기 부재). DifficultyMapping (T-0136) 1:N relation 의 역방향
// 필드 placeholder 는 두지 않음 — DifficultyMapping model 신설 시 T-0136 이 양방향
// relation 필드를 함께 추가 (Prisma 의 back-relation 요건 그 시점 충족).
model LlmProviderConfig {
  id          String   @id @default(cuid())
  provider    String
  endpointUrl String
  apiKey      String
  modelId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

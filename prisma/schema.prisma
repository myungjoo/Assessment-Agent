// Prisma schema вҖ” T-0033 (init) + T-0034 (Person model + мІ« migration) мң„м—җ
// T-0035 к°Җ ServiceIdentity model + PersonвҶ”ServiceIdentity 1:N relation +
// `@@unique([personId, service])` invariant лҘј м¶”к°Җн•ңлӢӨ.
//
// Prisma 7.x лӘЁлҚё (Prisma 5.x мҷҖ м°Ёмқҙ):
//   - datasource.url мқҖ schema к°Җ м•„лӢҢ `prisma.config.ts` м—җм„ң adapter лЎң inject.
//     ліё schema лҠ” provider л§Ң л°•м ң вҖ” runtime connection мқҖ PrismaClient мқҳ adapter
//     мғқм„ұмһҗ мҳөм…ҳ (`@prisma/adapter-pg`) к°Җ DATABASE_URL мқ„ мқҪм–ҙ pg Pool мқ„ кө¬м„ұ.
//   - м¶”к°Җ dependency `@prisma/adapter-pg` к°Җ ліё кІ°м •мқҳ implication мңјлЎң мһҗлҸҷ лҸ„мһ…
//     (T-0033 acceptance).
//
// T-0035 мұ…мһ„ лІ”мң„:
//   - ServiceIdentity model 1 к°ң м¶”к°Җ (id / personId / service / externalId /
//     isPrimary / createdAt / updatedAt).
//   - Person.serviceIdentities relation н•„л“ң 1 мӨ„ м¶”к°Җ.
//   - `@@unique([personId, service])` invariant вҖ” 1 Person мқҳ лҸҷмқј service мӨ‘ліө кёҲм§Җ.
// м¶”к°Җ entity (Group / Part / User / Assessment / Contribution / Summary /
// LlmProviderConfig / DifficultyMapping / PermissionDeniedRecord) лҠ” T-0036+
// мқҳ мұ…мһ„мқҙлҜҖлЎң ліё task мқҳ Out of Scope.

datasource db {
  provider = "postgresql"
}

// Prisma Client (TypeScript) мғқм„ұкё°. NestJS service / controller к°Җ мӮ¬мҡ©н•  type мқҳ source.
generator client {
  provider = "prisma-client-js"
}

// Person вҖ” data-model.md В§2 row 1 мқҳ мөңмҶҢ м»¬лҹј + ServiceIdentity 1:N relation.
// T-0035 к°Җ `serviceIdentities` relation н•„л“ңлҘј м¶”к°Җ вҖ” Prisma мқҳ м–‘л°©н–Ҙ relation
// мҡ”кұҙ (back-relation н•„л“ң н•„мҲҳ). м¶”к°Җ м»¬лҹј (group / part / лҸҷлӘ…мқҙмқё л“ұ) мқҖ T-0036+.
model Person {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 1 Person мқҖ 0+ к°ңмқҳ ServiceIdentity лҘј к°Җм§„лӢӨ (REQ-023 / data-model.md В§3 кҙҖкі„ 1).
  // hard delete мӢң Cascade лЎң ServiceIdentity лҸҷл°ҳ мӮӯм ң (ServiceIdentity model мқҳ
  // `onDelete: Cascade` к°Җ м–‘л°©н–Ҙ мқҳлҜёлҘј л°•м ң). soft delete (active=false) мӢңм—җлҠ”
  // ліё cascade л°ңлҸҷ м•Ҳ н•Ё вҖ” ServiceIdentity лҠ” к·ёлҢҖлЎң ліҙмЎҙ.
  serviceIdentities ServiceIdentity[]
}

// ServiceIdentity вҖ” data-model.md В§2 row 2 + В§3 кҙҖкі„ 1 + REQ-023 / REQ-024 cover.
// 1 Person мқҳ N м„ңл№„мҠӨ ID лҘј л§Өн•‘ (github.com / github.sec.samsung.net /
// github.ecodesamsung.com / confluence.sec.samsung.net л“ұ). isPrimary к°Җ REQ-024
// invariant (1 Person лӢ№ м •нҷ•нһҲ 1 primary) мқҳ schema-level н‘ңмӢқ вҖ” service-layer
// к°•м ң (м •нҷ•нһҲ 1 row) лҠ” нӣ„мҶҚ T-0036 мұ…мһ„. ліё task лҠ” schema мқҳ `@@unique` л§Ң л°•м ң.
//
// service н•„л“ңлҠ” ліё task м—җм„ң String мңјлЎң мң м§Җ вҖ” enum лҸ„мһ… / lookup table кІ©мғҒмқҖ
// P4 м§„мһ… мӢң лі„лҸ„ ADR к¶ҢмһҘ (task мқҳ Follow-ups В§149 м°ёмЎ°).
model ServiceIdentity {
  id         String   @id @default(cuid())
  personId   String
  service    String
  externalId String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Person кіј мқҳ N:1 вҖ” Person мқҳ hard delete мӢң ServiceIdentity лҸ„ cascade мӮӯм ң.
  // soft delete мқҳ кІҪмҡ° active flag л§Ң toggle мқҙлҜҖлЎң ліё cascade лҠ” л°ңлҸҷ м•Ҳ н•Ё.
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  // 1 Person мқҙ лҸҷмқј service мқҳ ID 2 к°ң к°Җм§Ҳ мҲҳ м—ҶмқҢ invariant (REQ-023 ліҖнҳ•).
  // мҳҲ: лҸҷмқј person мқҙ github.com мқҳ ID 2 к°ңлҘј л“ұлЎқн•  мҲҳ м—ҶлӢӨ вҖ” м„ңл№„мҠӨ мёЎ user мқҳ
  // 1:1 л§Өн•‘ к°Җм •.
  @@unique([personId, service])
}

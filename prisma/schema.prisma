// Prisma schema — T-0033 (init) + T-0034 (Person model + 첫 migration) +
// T-0035 (ServiceIdentity model + Person↔ServiceIdentity 1:N relation +
// `@@unique([personId, service])` invariant) 위에
// T-0039 가 Group + Part + PersonGroupMembership (join) model 3 종과
// Person↔Part N:1 + Person↔Group N:M (via join) relation 을 추가한다.
//
// Prisma 7.x 모델 (Prisma 5.x 와 차이):
//   - datasource.url 은 schema 가 아닌 `prisma.config.ts` 에서 adapter 로 inject.
//     본 schema 는 provider 만 박제 — runtime connection 은 PrismaClient 의 adapter
//     생성자 옵션 (`@prisma/adapter-pg`) 가 DATABASE_URL 을 읽어 pg Pool 을 구성.
//   - 추가 dependency `@prisma/adapter-pg` 가 본 결정의 implication 으로 자동 도입
//     (T-0033 acceptance).
//
// T-0039 책임 범위:
//   - Group model 1 개 추가 (id / name / createdAt / updatedAt).
//   - Part model 1 개 추가 (id / name unique / createdAt / updatedAt).
//   - PersonGroupMembership join model (id / personId / groupId / createdAt;
//     `@@unique([personId, groupId])` — 동일 Person 의 동일 Group 중복 소속 금지).
//   - Person.partId nullable + Person.part / Person.groups relation 필드.
//   - Part.persons / Group.memberships reverse relation 필드.
//
// 본 task 의 schema 차원 결정:
//   - Person.partId 는 **nullable** 유지. REQ-028 의 mandatory 1 Part invariant 는
//     service-layer (후속 T-0040) 책임. 본 task 는 schema 차원에서 (a) 기존 Person
//     row 의 default Part seed migration 부재 + (b) NOT NULL 전환 의 2 단계 cost
//     를 회피 — nullable + Follow-up 명시.
//   - Person → Part cascade: `onDelete: SetNull` 채택 안 함, default `Restrict`
//     (Prisma 의 default behaviour — FK constraint 가 P2003 throw). 이유: REQ-028
//     "Part 정확히 1" invariant 의 schema 차원 enforce — 소속 Person 1+ 일 때 Part
//     삭제를 막아 dangling reference 자체를 차단. 모든 Person 을 다른 Part 로
//     재배치한 뒤에야 Part 삭제 가능 (service-layer 책임).
//   - PersonGroupMembership → Person cascade: `onDelete: Cascade` — Person 삭제 시
//     모든 membership row 동반 삭제. 단 Person 의 hard delete 는 REQ-026 에 따라
//     발생 안 함 (soft delete `active=false`), 본 cascade 는 안전망.
//   - PersonGroupMembership → Group cascade: `onDelete: Cascade` — Group 삭제 시
//     모든 membership row 동반 삭제. Group 은 hard delete 채택 (소속 Person 0+
//     무관 — REQ-028 "임의 group" semantics 가 Group 의 자유로운 삭제 허용).
//
// 추가 entity (User / Assessment / Contribution / Summary / LlmProviderConfig /
// DifficultyMapping / PermissionDeniedRecord) 는 T-0040+ 의 책임이므로 본 task
// 의 Out of Scope.

datasource db {
  provider = "postgresql"
}

// Prisma Client (TypeScript) 생성기. NestJS service / controller 가 사용할 type 의 source.
generator client {
  provider = "prisma-client-js"
}

// Person — data-model.md §2 row 1 의 최소 컬럼 + ServiceIdentity 1:N relation.
// T-0035 가 `serviceIdentities` relation 필드를 추가 — Prisma 의 양방향 relation
// 요건 (back-relation 필드 필수). 추가 컬럼 (group / part / 동명이인 등) 은 T-0036+.
model Person {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 1 Person 은 0+ 개의 ServiceIdentity 를 가진다 (REQ-023 / data-model.md §3 관계 1).
  // hard delete 시 Cascade 로 ServiceIdentity 동반 삭제 (ServiceIdentity model 의
  // `onDelete: Cascade` 가 양방향 의미를 박제). soft delete (active=false) 시에는
  // 본 cascade 발동 안 함 — ServiceIdentity 는 그대로 보존.
  serviceIdentities ServiceIdentity[]

  // T-0039 — Person ↔ Part N:1 (mandatory in service-layer; schema 차원 nullable).
  // REQ-028 의 "조직도 파트 정확히 1" invariant 의 service-layer 강제는 후속 T-0040
  // 책임. 본 task 는 schema 차원에서 nullable 유지 + Follow-up 명시.
  // Part 삭제 시 본 row 의 partId 는 default `Restrict` (FK constraint P2003) 로
  // 보호된다 — 모든 Person 의 part 가 재배치된 후에야 Part 삭제 가능.
  partId String?
  part   Part?   @relation(fields: [partId], references: [id])

  // T-0039 — Person ↔ Group N:M via PersonGroupMembership join entity.
  // REQ-028 의 "임의 group 다중 소속 가능" semantics — 1 Person 은 0+ Group.
  // PersonGroupMembership 의 `onDelete: Cascade` 가 Person 삭제 시 모든 membership
  // row 를 동반 삭제 (안전망 — Person 은 REQ-026 에 따라 hard delete 채택 안 함).
  groups PersonGroupMembership[]

  // T-0110 (ADR-0006 Decision §1 / §3 / §6) — Person ↔ Assessment / Summary back-relation.
  // 1 Person 은 0+ Assessment (period × scope cross product) + 0+ Summary (일/주/월) 를 가진다.
  // 두 model 모두 `onDelete: Cascade` (해당 model 의 relation 필드가 양방향 의미 박제) —
  // Person 의 hard delete 시 평가 결과 동반 삭제 (단 Person 은 soft delete 채택이라
  // 본 cascade 는 안전망. ServiceIdentity / PersonGroupMembership 의 기존 Cascade 정합).
  assessments Assessment[]
  summaries   Summary[]
}

// Group — data-model.md §2 row 3 + §3 관계 2 + REQ-028 의 schema 차원 박제.
// 1 Person 이 임의 다수 Group 에 소속 가능 (N:M) — PersonGroupMembership join 으로 표현.
// 본 task 는 schema 차원에서 hard delete 채택 — Group 삭제 시 PersonGroupMembership
// row 들이 cascade 동반 삭제. Person 의 part 와 달리 Group 은 "조직도 파트" 가 아닌
// 자유로운 grouping 이므로 자유로운 삭제 허용 (REQ-028 "임의 group" semantics).
model Group {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // reverse relation — 1 Group 은 0+ PersonGroupMembership row 를 가진다.
  memberships PersonGroupMembership[]
}

// Part — data-model.md §2 row 4 + §3 관계 3 + REQ-028 의 schema 차원 박제.
// "조직도 파트" — 1 Person 은 정확히 1 Part 에 소속 (mandatory invariant 는
// service-layer 책임, 본 task 는 schema 차원에서 nullable 유지).
// `name @unique` — 동일 이름의 Part 중복 금지 (조직도의 고유성 가정).
// Part → Person 의 cascade 는 default `Restrict` (Prisma 의 default behaviour) —
// 소속 Person 1+ 인 Part 삭제 시 FK constraint (P2003) 가 throw, dangling
// reference 차단. service-layer 가 사전에 모든 Person 의 part 를 재배치 책임.
model Part {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // reverse relation — 1 Part 는 0+ Person 을 거느린다.
  persons Person[]
}

// PersonGroupMembership — Person ↔ Group 의 N:M join entity (data-model.md §3
// 관계 2). 각 row 가 (personId, groupId) 한 쌍을 박제. `@@unique([personId, groupId])`
// invariant — 동일 Person 의 동일 Group 중복 소속 금지.
//
// cascade 정책 (schema.prisma 헤더 결정 §28–37 참조):
//   - Person 삭제 시 본 row Cascade 동반 삭제 (안전망 — Person 은 soft delete 채택).
//   - Group 삭제 시 본 row Cascade 동반 삭제 (Group 의 자유 삭제 semantics).
model PersonGroupMembership {
  id        String   @id @default(cuid())
  personId  String
  groupId   String
  createdAt DateTime @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([personId, groupId])
}

// User — data-model.md §2 row "User" + REQ-043 (ID/Password) + REQ-044 (3 등급).
// T-0080 — ADR-0008 후속 chain 첫 task. AuthModule (T-0081) 의 prerequisite.
//
// 책임 경계:
//   - 로그인 계정 (서비스 사용자). Person 과 conceptual 분리 — User 는 시스템 인증
//     식별자, Person 은 평가 대상자 (data-model.md §2 박제).
//   - User ↔ Person 0..1:0..1 relation 은 본 task 의 Out of Scope — data-model.md
//     §3 관계 7 의 AuthModule 책임 deferral 정합. 향후 별도 task 가 relation 컬럼
//     (예: personId String? @unique + relation 필드) 추가.
//
// 컬럼 결정:
//   - email @unique — REQ-043 의 로그인 identifier. unique constraint 위반 시
//     Prisma 가 P2002 throw (UserRepository.create 에서 catch 0 — caller 책임).
//   - hashedPassword — raw String. hashing logic (bcrypt / argon2 등) 자체는 T-0081
//     의 AuthService layer 책임 — 본 schema 는 hashed 결과를 저장만 한다 (hashing
//     알고리즘 / cost factor 같은 결정은 ADR-0008 후속 task 가 별도 박제).
//   - role — String literal ("SuperAdmin" / "Admin" / "User") 의 단순 박제. Prisma
//     enum 도입 / role lookup table 격상은 별도 ADR 의 책임 — Person model 의
//     ServiceIdentity.service 컬럼 (String 박제) 정공법 정합. service-layer
//     (T-0081 AuthService) 가 값 invariant 검증 책임. self-demote 차단 (REQ-044)
//     은 T-0083 의 책임.
//   - createdAt / updatedAt — Person / Group / Part 와 동일한 표준 timestamp 패턴.
//
// cascade 정책:
//   - User 삭제 시의 cascade 는 본 task 에서 결정 안 함 — relation 컬럼 부재
//     (Person/RefreshToken 등 후속 entity 와의 관계가 아직 박제 안 됨) 으로 cascade
//     의 적용 대상이 없음. relation 추가 시 별도 task 가 cascade 정책 박제.
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  role           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // T-0221 (ADR-0024 Decision §2) — User ↔ instance binding back-relation.
  // 1 User 는 0+ 개의 UserInstanceAccess (허용 instance binding) 를 가진다.
  // Prisma 양방향 relation 요건 (UserInstanceAccess.user 의 back-field).
  // User hard delete 시 UserInstanceAccess 의 `onDelete: Cascade` 가 binding row 를
  // 동반 정리 (고아 binding 0). PersonGroupMembership Cascade 패턴 정합.
  instanceAccess UserInstanceAccess[]

  // T-0485 (ADR-0044 Decision §1) — User ↔ ExportJob / ImportJob back-relation.
  // Prisma 양방향 relation 요건 (ExportJob.requestedBy / ImportJob.requestedBy 의
  // back-field). 1 User 는 0+ ExportJob / 0+ ImportJob 를 발화 — 누가 dump/restore 를
  // 일으켰는지 추적 (ADR-0044 §1 requestedBy 정합). cascade 는 ExportJob / ImportJob
  // 측 onDelete: Restrict 이므로 User hard delete 시 dangling job row 차단 — User
  // schema 의 기존 필드 변경 0 (back-field 추가만 — additive, ADR-0044 Cross-Module
  // Impact "User schema 변경 0" 정신: 기존 컬럼·관계 무손상).
  exportJobs ExportJob[] @relation("UserExportJobs")
  importJobs ImportJob[] @relation("UserImportJobs")
}

// UserInstanceAccess — ADR-0024 Decision §2 의 schema 박제 (T-0221).
// non-Admin audit 조회의 User↔instance binding join entity. 한 사용자가 조회할 수
// 있는 instance 집합 (allowlist) 을 영속한다 — 각 row 가 (userId, instanceRef) 한
// 쌍을 박제. own-instance 필터의 `instanceRef in (SELECT instanceRef WHERE userId=?)`
// allowlist lookup 의 source (Decision §3 결선은 후속 service slice 책임).
//
// 설계 결정 (ADR-0024 Decision §2 — PersonGroupMembership L131~141 join 패턴 mirror):
//   - binding 대상 instanceRef 는 PermissionDeniedRecord.instanceRef 와 동일 식별자
//     (GitHub configured host / Confluence 풀 REST base URL free-form 문자열,
//     ADR-0022 §1). 신규 식별자 체계 도입 0 — 문자열을 그대로 binding 단위로 쓴다.
//   - `@@unique([userId, instanceRef])` — 동일 (user, instance) 중복 binding 차단
//     (PersonGroupMembership `@@unique([personId, groupId])` 정합). 정규화값 기준
//     중복 강제 (정규화는 후속 repository slice 의 입력 경로 책임, ADR-0024 §4).
//   - `@@index([userId])` — allowlist lookup (`WHERE userId = ?`) 의 조회 경로.
//     `@@unique([userId, instanceRef])` leading-edge 로 부분 cover 되나 ADR-0024 §2
//     채택 모델대로 명시 박제.
//   - `onDelete: Cascade` — User hard delete 시 binding row 동반 정리 (고아 binding 0,
//     PersonGroupMembership Cascade 정합). audit record (PermissionDeniedRecord) 는
//     standalone (ADR-0022 §5) 이라 본 Cascade 와 무관 — binding 삭제는 record 미접촉.
//   - createdAt 만 보유, updatedAt 미정의 — binding row 는 부여 시점 1 회 기록
//     (immutable, PersonGroupMembership 동형 패턴). 재부여는 삭제 후 재생성.
//
// 본 slice 는 empty table 추가라 동작 변경 0 (binding 0 시작 = breaking change 0,
// ADR-0024 §5). non-Admin 은 binding row 가 채워지기 전까지 여전히 빈 배열 placeholder.
// repository / service 필터 결선 / endpoint 동작 변경은 ADR-0024 후속 slice 책임.
//
// token / secret 미포함 invariant (CLAUDE.md §9) — binding 은 (userId, instanceRef)
// 식별자만 보유, token / 자격증명 컬럼을 정의하지 않는다 (schema 차원 강제).
model UserInstanceAccess {
  id          String   @id @default(cuid())
  userId      String
  instanceRef String
  createdAt   DateTime @default(now())

  // User 와 의 N:1 — User 의 hard delete 시 binding row 동반 cascade 삭제.
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 동일 (user, instance) 중복 binding 금지 (ADR-0024 Decision §2 invariant).
  @@unique([userId, instanceRef])
  // allowlist lookup (`WHERE userId = ?`) 조회 경로 (ADR-0024 Decision §2).
  @@index([userId])
}

// ServiceIdentity — data-model.md §2 row 2 + §3 관계 1 + REQ-023 / REQ-024 cover.
// 1 Person 의 N 서비스 ID 를 매핑 (github.com / github.sec.samsung.net /
// github.ecodesamsung.com / confluence.sec.samsung.net 등). isPrimary 가 REQ-024
// invariant (1 Person 당 정확히 1 primary) 의 schema-level 표식 — service-layer
// 강제 (정확히 1 row) 는 후속 T-0036 책임. 본 task 는 schema 의 `@@unique` 만 박제.
//
// service 필드는 본 task 에서 String 으로 유지 — enum 도입 / lookup table 격상은
// P4 진입 시 별도 ADR 권장 (task 의 Follow-ups §149 참조).
model ServiceIdentity {
  id         String   @id @default(cuid())
  personId   String
  service    String
  externalId String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Person 과 의 N:1 — Person 의 hard delete 시 ServiceIdentity 도 cascade 삭제.
  // soft delete 의 경우 active flag 만 toggle 이므로 본 cascade 는 발동 안 함.
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  // 1 Person 이 동일 service 의 ID 2 개 가질 수 없음 invariant (REQ-023 변형).
  // 예: 동일 person 이 github.com 의 ID 2 개를 등록할 수 없다 — 서비스 측 user 의
  // 1:1 매핑 가정.
  @@unique([personId, service])
}

// Assessment — ADR-0006 Decision §1 + data-model.md §2 / §3 관계 4 (Person↔Assessment).
// 평가 결과의 unit. Person × period (일/주/월) × scope (commit/document/aggregate) 의
// cross product. 평가 결과값 (난이도/기여도/양/LLM 정성 평가문) 만 보유.
//
// 🔥 raw 본문 컬럼 0 (R-59 / REQ-032 / ADR-0006 Decision §4 schema-level 강제):
//   commit message 본문 / diff / 문서 본문 / Confluence page 본문 컬럼을 **정의하지 않는다**.
//   "저장하지 않는다" 를 application-layer 검증이 아닌 schema 차원 (컬럼 자체의 부재) 으로
//   보장한다 — schema 에 자리가 없으면 저장 자체가 불가. 외부 본문이 필요하면 Contribution 의
//   참조 식별자 (sourceUrl / sourceRef) 로 재수집 (REQ-031). narrative 는 LLM 생성 결과물
//   이므로 raw 아님 (R-59 적용 외).
//
// 컬럼 결정 (ADR-0006 Decision §1 과 1:1):
//   - period / scope / difficulty 는 enum-as-String literal 박제 (ServiceIdentity.service /
//     User.role 정공법 정합 — Prisma enum 격상은 별도 ADR). 값 invariant 는 service-layer 책임.
//   - contributionScore 는 Decimal (정규화 수치 — REQ-036 상대 비교 가능 형태, Float 부동소수
//     오차 회피). @db.Decimal(p,s) 구체 precision/scale 은 후속 schema task 책임 (default 시작).
//   - updatedAt **미정의** — Assessment 는 immutable (재평가는 hard delete 후 재생성,
//     REQ-037/REQ-041). data-model.md §5 정합.
model Assessment {
  id                String   @id @default(cuid())
  personId          String
  period            String
  scope             String
  periodStart       DateTime
  difficulty        String
  contributionScore Decimal
  volume            Int
  narrative         String
  createdAt         DateTime @default(now())

  // Person N:1 — Person 의 hard delete 시 Assessment 동반 cascade (ADR-0006 Decision §6).
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  // 1 Assessment 는 0+ Contribution 으로 구성 (ADR-0006 Decision §2 / §3 관계 5).
  contributions Contribution[]

  // 동일 Person 의 동일 (period, scope, periodStart) 조합 중복 Assessment 차단 →
  // 재수집 중복 방지 (REQ-031) 의 schema-level backbone (ADR-0006 Decision §6).
  @@unique([personId, period, scope, periodStart])
  // 시계열 조회 (REQ-038) 용 index 후보 (ADR-0006 Decision §6).
  @@index([personId, period, periodStart])
}

// Contribution — ADR-0006 Decision §2 + data-model.md §3 관계 5 (Assessment↔Contribution).
// 개별 기여 단위 (단일 commit / 단일 PR / 단일 문서 변경). N Contribution 이 1 Assessment 로
// aggregate. 참조 식별자만 보유, raw 본문 미저장 (REQ-032).
//
// 🔥 raw 본문 컬럼 0 (R-59 / ADR-0006 Decision §4):
//   commit body / diff / 문서 본문 컬럼 정의 안 함. sourceUrl (외부 GitHub / Confluence URL) +
//   sourceRef (commit SHA / PR number / page version ID) 만으로 필요 시 재수집 (REQ-031).
//   sourceUrl / sourceRef 는 외부 본문을 가리키는 pointer 일 뿐 본문 자체가 아님.
//
// updatedAt **미정의** — Contribution 은 immutable (ADR-0006 Decision §2).
model Contribution {
  id                String   @id @default(cuid())
  assessmentId      String
  sourceType        String
  sourceUrl         String
  sourceRef         String
  difficulty        String
  contributionScore Decimal
  volume            Int
  createdAt         DateTime @default(now())

  // Assessment N:1 — Assessment 의 hard delete (REQ-041 Admin manual delete) 시
  // component Contribution 동반 cascade 삭제 (ADR-0006 Decision §6).
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  // 동일 Assessment 안에서 동일 unitId (= sourceRef) 의 Contribution 중복 차단 →
  // REQ-031 재수집 중복 방지의 Contribution-level mirror (Assessment-level idempotency
  // `@@unique([personId, period, scope, periodStart])` 와 짝). application-layer dedup
  // (후속 write service slice 의 reset-and-recreate) 의 schema backbone (ADR-0033 §4).
  @@unique([assessmentId, sourceRef])
}

// Summary — ADR-0006 Decision §3 + data-model.md §3 관계 6 (Person↔Summary).
// 일·주·월 단위 요약 평가문. Person N:1 (default). LLM 정성 평가문 + Metric 수치.
// Group/Part aggregate Summary 는 별도 entity 신설 안 함 — view-time 계산 (ADR-0006
// Alternatives (c) defer). 동일 Group/Part 소속 Person 들의 Summary 를 query-time 집계.
//
// 🔥 raw 본문 컬럼 0 (R-59 / ADR-0006 Decision §4):
//   narrative 는 LLM 정성 요약 평가문 (LLM 생성 결과물 — raw 아님). raw 본문 컬럼 정의 안 함.
//
// updatedAt **미정의** — Summary 는 재계산 가능하나 본 ADR 은 immutable 로 보고 재계산 =
// hard delete 후 재생성으로 처리 (ADR-0006 Decision §3).
model Summary {
  id          String   @id @default(cuid())
  personId    String
  period      String
  periodStart DateTime
  narrative   String
  metricScore Decimal
  createdAt   DateTime @default(now())

  // Person N:1 — Person 의 hard delete 시 Summary 동반 cascade (ADR-0006 Decision §6).
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  // 한 person 의 한 granularity·구간 요약은 정확히 1 row (ADR-0035 §Decision 4).
  // (personId, period, periodStart) 좌표가 aggregate 재집계 reset-and-recreate 의
  // idempotency key — 같은 좌표 Summary 중복을 schema-level 로 차단해 application-layer
  // aggregate write service 의 schema backbone 을 박제한다.
  @@unique([personId, period, periodStart])
  // 시계열 조회 (REQ-038) 용 index 후보 (ADR-0006 Decision §6).
  @@index([personId, period, periodStart])
}

// LlmProviderConfig — data-model.md §2 row "LlmProviderConfig" + §3 관계 8 +
// REQ-049/051~055. T-0135 (P4 LLM provider 추상화 scaffold). 5 provider
// (custom / Azure OpenAI / Anthropic / Google Gemini / OpenAI) 별 설정 row —
// endpoint URL / API key / model 식별자.
//
// 컬럼 결정 (T-0135 acceptance §34):
//   - provider 는 enum-as-String literal 박제 (User.role / ServiceIdentity.service /
//     Assessment.period 정공법 정합 — Prisma enum 격상은 별도 ADR). 허용 집합의
//     single source 는 src/llm/llm-gateway.interface.ts 의 LlmProvider enum.
//     값 invariant 는 후속 service (T-0139) 책임.
//   - apiKey 는 ADR-0014 AES-256-GCM envelope 로 encryption-at-rest 저장 — 컬럼은
//     평문이 아니라 암호문(ciphertext) String 을 보관한다. write 경로
//     (LlmProviderConfigService.create/update) 가 LlmApiKeyCipher.encrypt 로 암호화
//     후 영속하고, read 경로는 sanitize(Omit apiKey)로 never-read-back, gateway
//     (LlmHttpGatewayService) 가 LLM 호출 시점에만 JIT decrypt 한다. ciphertext 도
//     문자열이라 String 타입은 정합.
//   - createdAt / updatedAt — Person / Group / Part 와 동일한 표준 timestamp 패턴.
//     LlmProviderConfig 는 mutable entity (data-model.md §5 — updatedAt 적용).
//
// **다중 row 모델** — 각 provider 별 1+ row, custom 은 3 model 슬롯 모두 차지 가능
// (REQ-051). GroupRepository 와 동일하게 `@unique` / `@@unique` **미정의** — unique
// 제약 없음 (P2002 분기 부재). DifficultyMapping (T-0137) 1:N relation 의 역방향
// 필드 `difficultyMappings` 를 추가 — Prisma 의 back-relation 요건 충족
// (DifficultyMapping 측이 `llmProviderConfigId` FK 보유, ADR-0011 §2 N:1).
model LlmProviderConfig {
  id          String   @id @default(cuid())
  provider    String
  endpointUrl String
  apiKey      String
  modelId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 역방향 relation — 본 config 를 가리키는 DifficultyMapping 슬롯들 (N:1 의 1 측).
  // custom provider 1 config 가 3 슬롯 모두 차지 가능 (REQ-051) → N row.
  difficultyMappings DifficultyMapping[]
}

// DifficultyMapping — data-model.md §2 row "DifficultyMapping" + §3 관계 8 +
// REQ-050/097. ADR-0011 이 확정한 3 결정 (§1 3 row 고정 cardinality / §2
// `llmProviderConfigId` FK 참조 N:1 / §3 fail-fast) 의 entity layer (T-0137).
// 3 난이도 슬롯 (easy / medium / hard) ↔ LlmProviderConfig 매핑.
//
// 컬럼 결정 (ADR-0011 §1·§2):
//   - difficulty 는 enum-as-String literal 박제 (LlmProviderConfig.provider /
//     User.role 정공법 정합 — Prisma enum 격상은 별도 ADR). 허용 집합의 single
//     source 는 src/llm/difficulty.ts 의 Difficulty union (`easy`/`medium`/`hard`).
//     `@@unique([difficulty])` 로 동일 난이도 슬롯 중복 row schema-level 차단
//     (ADR-0011 §1 3 row 고정 — 3 슬롯 unique). 값 invariant / 3 row 초과 거부는
//     후속 service (T-0138+) 책임.
//   - llmProviderConfigId 는 nullable FK (String?) — ADR-0011 §3 의 fail-fast 가
//     미설정 슬롯을 4xx 로 거부하므로 nullable 시작 안전 (seed 전 미설정 상태 허용,
//     3 row seed 자동화는 Follow-up). 가리켜진 LlmProviderConfig 의 modelId 가
//     매핑 대상 model 의 single source (denormalize 회피, ADR-0011 §2).
//   - onDelete: Restrict — 매핑에 사용 중인 LlmProviderConfig 삭제 차단
//     (ADR-0011 §2 RESTRICT 권장 — Admin 이 먼저 재지정 후 삭제). Person → Part
//     의 default Restrict 패턴과 정합.
//   - createdAt / updatedAt — 표준 timestamp 패턴 (mutable entity, 슬롯별 model
//     재지정 시 updatedAt 갱신 — T-0139 endpoint).
model DifficultyMapping {
  id                  String  @id @default(cuid())
  difficulty          String
  llmProviderConfigId String?

  llmProviderConfig LlmProviderConfig? @relation(fields: [llmProviderConfigId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([difficulty])
}

// PermissionDeniedRecord — ADR-0022 §1·§3·§4·§5 의 schema 박제 (T-0208).
// P4 GitHub / Confluence adapter 가 권한 거부 (401 / 403 / 권한 비가시 404) 시
// emit 하는 PermissionDeniedEvent 의 영속화 측 entity. 권한 거부 1 건을 박제하는
// append-only audit row — 한 번 기록되면 갱신되지 않는다 (immutable).
//
// 컬럼 결정 (ADR-0022 §1 필드 표 1:1):
//   - id — 전 model 공통 cuid PK 컨벤션.
//   - provider — 어느 adapter 의 이벤트인지 식별하는 enum-as-String literal
//     ("github" / "confluence"). 두 adapter 의 동형 이벤트를 단일 record 로 수용하는
//     discriminator. 값 invariant 는 service-layer 책임 (ServiceIdentity.service /
//     User.role 의 String-literal 정공법 정합 — Prisma enum 격상은 별도 ADR).
//   - instanceRef — 권한이 거부된 instance 식별자. GitHub 는 configured host
//     (예: github.sec.samsung.net), Confluence 는 풀 REST API base URL
//     (예: https://acme.atlassian.net/wiki/rest/api). 두 adapter 이벤트의 host /
//     baseUrl 비대칭을 단일 컬럼으로 정규화 (provider 와 함께 읽으면 의미 명확).
//     token / 자격증명을 base URL 에 절대 포함하지 않는다 (CLAUDE.md §9).
//   - resourceRef — 권한이 거부된 대상 REST path (예: /repos/{owner}/{repo}/commits).
//     이벤트의 path 를 그대로 수용. 외부 본문이 아닌 참조 식별자라 raw 미저장
//     invariant 정합 (ADR-0006 Contribution.sourceRef 동형 위상).
//   - principal — nullable. 권한 거부의 주체 (어느 ServiceIdentity / token 으로
//     호출했는가). 현 이벤트 shape 에는 principal 정보가 없어 (host / path / status
//     만) 현 단계에서는 항상 null. token 평문은 절대 저장 불가 (CLAUDE.md §9).
//     이벤트 shape 확장 + ServiceIdentity relation 은 후속 task 책임 — nullable
//     박제로 자리만 예약 (Person.partId nullable 패턴 정합).
//   - httpStatus — 거부를 유발한 HTTP status (401 / 403 / 권한 비가시 404).
//     status code 이름은 외부 표준이라 영어/숫자 그대로.
//   - reason — nullable. 거부 분류의 사람-친화 reason (예: "permission-denied" /
//     "not-found-or-hidden"). 이벤트 shape 에 reason 문자열이 없으므로 service-layer
//     가 httpStatus 로부터 도출하거나 null. token 평문 / 응답 본문은 절대 미포함.
//   - createdAt — 권한 거부 발생 (= emit) 시각. UTC 저장 (ADR-0012).
//
// updatedAt 미정의 (immutable, ADR-0022 §1) — audit row 는 한 번 기록되면 갱신되지
//   않는다 (Assessment / Contribution / Summary 의 immutable 패턴 + ADR-0012
//   mutable-only updatedAt 정합). 정정이 필요하면 새 row.
//
// @@unique 미정의 (append-only, ADR-0022 §3) — 동일
//   (provider, instanceRef, resourceRef, httpStatus) 반복 거부는 매 emit 마다 새
//   row 로 박제한다 (dedup 안 함). audit 는 발생 횟수·시점 자체가 신호이므로 중복
//   row 를 의도적으로 허용 — unique 제약을 두면 P2002 발화로 이 신호를 잃는다
//   (LlmProviderConfig 의 @@unique 미정의 = 다중 row 허용 패턴 정합).
//
// relation / FK 미정의 (standalone, ADR-0022 §5) — Person / User / ServiceIdentity
//   등 기존 model 과 relation 을 맺지 않는다. 이벤트가 principal 식별자를 싣지
//   않아 FK 도출 데이터가 0 이고, audit row 는 참조 대상 삭제와 무관하게 거부 이력이
//   보존돼야 하므로 (cascade 가 audit 영구 보존과 충돌) standalone 으로 박제.
//   다른 model 변경 0 — back-relation 필드 추가 0.
//
// token 평문·secret 미포함 invariant (CLAUDE.md §9) 를 schema 차원에서 박제 —
//   record schema 는 token / Authorization header / 응답 본문 컬럼을 정의하지
//   않는다. schema 에 자리가 없으면 저장 자체가 불가 (ADR-0006 raw 미저장
//   schema-level 강제 동형 기법).
//
// @@index 2종 (ADR-0022 §4) — 운영자의 audit 조회 패턴 (필터 컬럼 + createdAt
//   prefix, Assessment 의 시계열 @@index 동형):
//   - [instanceRef, createdAt] — "이 instance 의 최근 거부 이력" (instance × 기간).
//   - [provider, httpStatus, createdAt] — "github 의 403 거부를 기간별로"
//     (provider × status × 기간, audit dashboard).
//   @@index([createdAt]) 단독은 §4 상 후보일 뿐 — 위 2 composite index 의
//   leading-edge 로 부분 cover 되므로 본 task 에서는 추가하지 않는다 (Out of Scope).
model PermissionDeniedRecord {
  id          String   @id @default(cuid())
  provider    String
  instanceRef String
  resourceRef String
  principal   String?
  httpStatus  Int
  reason      String?
  createdAt   DateTime @default(now())

  @@index([instanceRef, createdAt])
  @@index([provider, httpStatus, createdAt])
}

// ExportJob / ImportJob — ADR-0044 Decision §1 (T-0485, P7 export/import 실배선 chain step 2).
// UC-07 export/import 의 비동기 진행 추적·재시도·감사 backbone. 책임 module 은 AssessmentModule
// (api.md L56 `/api/admin` 정합). 본 task 는 ADR-0044 §1 의 책임·필드 박제를 Prisma model 코드 +
// migration 으로 옮기는 schema layer 만 — controller/service 배선 / 누적 45 helper 호출 결선 /
// artifact 저장소 mechanism 선택은 후속 task (ADR-0044 §Out of scope / §Follow-ups).
//
// 🔥 raw 미저장 invariant (ADR-0044 §2 / REQ-032 / ADR-0006 schema-level 강제 동형):
//   ExportJob / ImportJob 의 어떤 필드도 raw commit message / diff / PR body / page 본문
//   컬럼을 두지 않는다. `artifactRef` 는 dump/upload artifact 의 **참조 식별자** (파일 경로 /
//   object key / handle) 일 뿐 본문이 아니며, `error` 는 사람-친화 실패 요약 (raw stack
//   trace / 응답 본문이 아님). schema 에 자리가 없으면 저장 자체가 불가 — Assessment /
//   Contribution / PermissionDeniedRecord 의 raw 미저장 schema-level 강제 동형 기법.
//
// 공통 enum (JobStatus) 채택 근거: ExportJob / ImportJob 의 status 4값 (PENDING / RUNNING /
//   SUCCEEDED / FAILED, ADR-0044 Decision §1) 이 완전히 동일하므로 enum 1 개로 share —
//   ADR-0044 §1 의 "status enum 은 공통 `JobStatus` 를 재사용하거나 ImportJob 전용 enum 으로 —
//   PENDING/RUNNING/SUCCEEDED/FAILED 4값을 정확히 반영하면 됨" 의 공통 안 선택. enum 중복
//   선언으로 인한 schema 표면 확대 회피. ExportScope / ImportMode 는 entity 별 고유라 별도.

// JobStatus — ExportJob / ImportJob 공통 진행 상태 enum (ADR-0044 Decision §1).
// PENDING (job row 생성, 실행 전) → RUNNING (실행 중) → SUCCEEDED / FAILED (종결).
// 향후 CANCELLED 추가 가능 (ADR-0044 §6.4 race 정책 — 본 task 는 4값만 박제).
enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

// ExportScope — Export dump 범위 enum (ADR-0044 Decision §1, UC-07 §6.1).
// FULL = 전체 entity 전 기간 / RANGE = 기간 한정 / PARTIAL = entity·인원 한정.
// scope=RANGE 시 dateRange 필드 활용, scope=PARTIAL 시 entitySelector 필드 활용 (Json).
// FULL 시 dateRange / entitySelector 모두 null. service-layer 가 값 invariant 검증 책임.
enum ExportScope {
  FULL
  RANGE
  PARTIAL
}

// ImportMode — Import 복원 모드 enum (ADR-0044 Decision §1, UC-07 §6.2).
// REPLACE (default) = 기존 row 삭제 후 snapshot 복원 (single $transaction all-or-nothing,
//   ADR-0033 reset-and-recreate 동형 — ADR-0044 Decision §3).
// MERGE = 기존 row 보존 + 추가 (conflict resolution 알고리즘은 후속 service task — ADR-0044
//   §Out of scope).
enum ImportMode {
  REPLACE
  MERGE
}

// ExportJob — ADR-0044 Decision §1 + UC-07 §8 NFR 의 async job 진행 추적 backbone.
// 한 Export operation 의 생명주기 (PENDING→RUNNING→SUCCEEDED/FAILED) 와 산출물
// (artifactRef / error) 를 추적하는 영속 record. Export 는 read-only 라 DB 무변화이므로
// 본 entity 자체가 job 의 audit trail (재실행마다 1 row, ADR-0044 §4 idempotency by nature).
//
// 컬럼 결정 (ADR-0044 §1 1:1):
//   - id — 전 model 공통 cuid PK 컨벤션.
//   - status — 공통 JobStatus enum (PENDING / RUNNING / SUCCEEDED / FAILED).
//   - scope — ExportScope enum (FULL / RANGE / PARTIAL).
//   - dateRange — nullable Json. scope=RANGE 시 {start, end} 직렬화 (구체 shape 은
//     후속 service task — ADR-0044 §Out of scope "구체 직렬화 형태").
//   - entitySelector — nullable Json. scope=PARTIAL 시 인원/entity 한정값 직렬화.
//   - requestedBy — User FK scalar (ADR-0044 §1 누가 dump 를 일으켰는지 추적).
//   - createdAt / startedAt? / finishedAt? — 생성 / 실행 시작 / 종결 시각 (PENDING 동안
//     startedAt null, 종결 전 finishedAt null — ADR-0044 §1).
//   - error — nullable 사람-친화 실패 요약 (raw stack trace 가 아닌 short message,
//     ADR-0044 §2 raw 미저장 정합).
//   - artifactRef — nullable. dump artifact 의 참조 식별자 (파일 경로 / object key /
//     handle). artifact 저장소 mechanism (filesystem vs object storage) 의 선택은
//     ADR-0044 §Out of scope — 후속 task 책임.
//
// updatedAt **미정의** — job row 는 status 전이 시 변경되나, ADR-0044 §4 의 "재시도 = 새
//   row" 정책 + Assessment / Summary 의 immutable 패턴 정합으로 status / startedAt /
//   finishedAt 갱신 자체는 단일 lifecycle 안의 표식이며 row 의 "기록 시점" 추적은 createdAt
//   하나로 충분 (data-model.md §5 mutable-only updatedAt 정합 — job 은 audit 성격).
//
// @@index([status, createdAt]) — UC-07 §8 status polling + 감사 조회 패턴.
//   "현재 RUNNING 중인 job 의 최근 순" / "FAILED job 의 기간별 감사" 의 leading-edge
//   필터 + 시계열 정렬을 cover (Assessment 의 시계열 @@index([personId, period,
//   periodStart]) 동형 패턴 — ADR-0006 Decision §6 정합).
//   (구체 추가 index 는 ADR-0044 §Out of scope — 최소 1 종만 박제.)
//
// FK cascade — onDelete: Restrict (Prisma default). User hard delete 시 job row 의
//   requestedBy 가 dangling reference 가 되지 않도록 차단. 운영자는 User 삭제 전 관련
//   job row 정리 책임 (DifficultyMapping → LlmProviderConfig 의 Restrict 패턴 정합).
//   ADR-0044 Cross-Module Impact "User schema 변경 0" 의 의도는 *기존 컬럼·관계* 무손상 —
//   Prisma 양방향 relation 요건상 User 측 explicit back-relation 필드 (exportJobs /
//   importJobs) 2 줄은 additive 로 추가 (FK 컬럼 / DB schema 변경 0, SQL impact 0).
model ExportJob {
  id             String      @id @default(cuid())
  status         JobStatus   @default(PENDING)
  scope          ExportScope
  dateRange      Json?
  entitySelector Json?
  requestedById  String
  createdAt      DateTime    @default(now())
  startedAt      DateTime?
  finishedAt     DateTime?
  error          String?
  artifactRef    String?

  // User N:1 — User hard delete 차단 (Restrict). 운영자가 사전 정리 책임.
  requestedBy User @relation("UserExportJobs", fields: [requestedById], references: [id], onDelete: Restrict)

  // status polling + 감사 조회 leading-edge index (ADR-0044 Decision §1, UC-07 §8).
  @@index([status, createdAt])
}

// ImportJob — ADR-0044 Decision §1 + §3 (Import atomic transaction invariant).
// 한 Import operation 의 생명주기와 산출물을 추적하는 영속 record. Import 는 destructive
// 이나 ADR-0044 §3 의 single `$transaction` all-or-nothing 으로 부분 복원 상태 0 (ADR-0033
// reset-and-recreate 동형). 재시도 = 새 row (ADR-0044 §4 immutable record 정신).
//
// 컬럼 결정 (ADR-0044 §1 1:1, ExportJob 공통 필드 + ImportJob 고유):
//   - id / status / requestedBy / createdAt / startedAt? / finishedAt? / error /
//     artifactRef — ExportJob 와 동일 공통 필드. status 는 공통 JobStatus enum 재사용.
//   - mode — ImportMode enum (REPLACE / MERGE), default REPLACE (ADR-0044 §1).
//   - restoredRowCount — nullable Int. SUCCEEDED 시 복원된 row 수 요약
//     (UC-07 §8 (e) Import postcondition). PENDING / RUNNING / FAILED 동안 null.
//
// @@index([status, createdAt]) — ExportJob 와 동형 status polling + 감사 조회 패턴.
//
// FK cascade — onDelete: Restrict, User schema 변경 0 (ExportJob 정합).
model ImportJob {
  id               String     @id @default(cuid())
  status           JobStatus  @default(PENDING)
  mode             ImportMode @default(REPLACE)
  requestedById    String
  createdAt        DateTime   @default(now())
  startedAt        DateTime?
  finishedAt       DateTime?
  error            String?
  artifactRef      String?
  restoredRowCount Int?

  // User N:1 — User hard delete 차단 (Restrict). ExportJob 정합.
  requestedBy User @relation("UserImportJobs", fields: [requestedById], references: [id], onDelete: Restrict)

  // status polling + 감사 조회 leading-edge index (ADR-0044 Decision §1, UC-07 §8).
  @@index([status, createdAt])
}
